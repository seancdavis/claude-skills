{
  "permissions": {
    "allow": [
      "Bash(grep:*)",
      "Bash(tree:*)",
      "WebSearch",
      "Bash(git commit:*)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:neon.com)",
      "WebFetch(domain:docs.astro.build)",
      "Bash(claude /plugin install:*)",
      "Bash(wc:*)",
      "Bash(npx prettier:*)",
      "Bash(claude:*)",
      "Bash(python3:*)",
      "Bash(while read f)",
      "Bash(do jq -r '.permissions.allow[]? // empty' \"$f\" done)",
      "Bash(do jq:*)",
      "Bash(done)",
      "Bash(/dev/null -exec echo \"=== {} ===\" ; -exec cat {} ;)",
      "Bash(gh pr:*)"
    ]
  }
}
